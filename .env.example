# Django
SECRET_KEY=your-secret-key-here
DEBUG=True

# Database (PostgreSQL) - use 'postgres' for Docker, 'localhost' for local dev
DB_NAME=deepfake_db
DB_USER=deepfake_user
DB_PASSWORD=deepfake_password
DB_HOST=postgres
DB_PORT=5432

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.44

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.44:3000

# CSRF (comma-separated origins, include port)
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://192.168.1.44:8000

# Media files
MEDIA_ROOT=media

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
